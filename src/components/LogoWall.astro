---
import Reveal from './Reveal.astro'
import Image from './Image.astro'
import { logos } from '../data/brands'

const { title = 'Brands that trust Conekt Ads' } = Astro.props
---

<section class="section--tight">
  <div class="wrap">
    <Reveal as="p" class="brands__title">{title}</Reveal>
    <Reveal class="logowall" delay="d1">
      {logos.map((logo) => (
        <div class="logowall__cell">
          <Image src={logo.src} alt={logo.alt} />
        </div>
      ))}
    </Reveal>
  </div>
</section>
