---
import { contact } from '../data/site'
---

<footer>
  <div class="wrap ftop">
    <div>
      <a class="wordmark" href="/">
        <span class="name">Conekt<span class="dot">.</span></span>
        <span class="sub">Ads</span>
      </a>
      <p class="ftag">
        India&apos;s tech-enabled outdoor advertising partner. Making brands unmissable across every format.
      </p>
    </div>
    <div>
      <p class="footer__heading">Services</p>
      <a href="/services#ooh">OOH Hoardings</a>
      <a href="/services#dooh">DOOH Screens</a>
      <a href="/services#auto">Auto, Car &amp; Cab Branding</a>
      <a href="/services#bus">Bus &amp; Mobile LED</a>
      <a href="/services/newspaper-jacket-advertising">Newspaper Jackets</a>
    </div>
    <div>
      <p class="footer__heading">Company</p>
      <a href="/work">Our work</a>
      <a href="/coverage">Coverage</a>
      <a href="/#why">Why Conekt</a>
      <a href="/contact">Contact</a>
    </div>
    <div class="fcontact">
      <p class="footer__heading">Get in touch</p>
      <a href={`mailto:${contact.email}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="m3 7 9 6 9-6"></path>
        </svg>
        {contact.email}
      </a>
      <a href={contact.phoneHref}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2Z"></path>
        </svg>
        {contact.phone}
      </a>
      <a href={contact.altPhoneHref}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2Z"></path>
        </svg>
        {contact.altPhone}
      </a>
      <a href="https://maps.google.com/?q=JP%20Nagar%2C%20Bengaluru%2C%20India" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11Z"></path>
          <circle cx="12" cy="10" r="2.5"></circle>
        </svg>
        {contact.address}
      </a>
    </div>
  </div>
  <div class="wrap fbot">
    <span>&copy; 2026 Conekt Ads. All rights reserved.</span>
    <span>Making Brands Unmissable.</span>
  </div>
</footer>
