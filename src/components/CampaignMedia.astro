---
import Image from './Image.astro'
import { normalizeImageSrc } from '../data/imageSizes'

const { campaign } = Astro.props
const src = normalizeImageSrc(campaign.image)
const isVideo = /\.(mp4|webm|ogg)$/i.test(src.split('?')[0])
---

{isVideo ? (
  <video
    data-video-src={src}
    data-lazy-video
    aria-label={campaign.alt}
    autoplay
    loop
    muted
    playsinline
    preload="none"
  ></video>
) : (
  <Image src={src} alt={campaign.alt} sizes="(min-width: 900px) 32vw, 86vw" />
)}
