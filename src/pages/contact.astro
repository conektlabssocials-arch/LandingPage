---
import BaseLayout from '../layouts/BaseLayout.astro'
import Reveal from '../components/Reveal.astro'
import { pages, contact } from '../data/site'
import '../styles/pages/contact.css'

const seo = pages['/contact']
const sheetsUrl = import.meta.env.VITE_GOOGLE_SHEETS_WEB_APP_URL?.trim() || ''
const formats = [
  'OOH Hoardings',
  'DOOH Screens',
  'Auto Branding',
  'Bus Branding',
  'Mobile LED Vehicles',
  'Car Branding',
  'Newspaper Jackets',
  'Not sure — recommend a mix',
]
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://conektads.com' },
      { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://conektads.com/contact' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPoint',
    contactType: 'sales',
    email: contact.email,
    telephone: contact.phone,
    areaServed: 'IN',
    availableLanguage: ['English', 'Hindi', 'Kannada'],
  },
]
---

<BaseLayout title={seo.title} description={seo.description} path="/contact" image={seo.image} schema={schema} screenLabel="Contact">
  <section class="section contactwrap" id="enquiry">
    <div class="wrap contactgrid">
      <div class="contact__intro">
        <Reveal as="span" class="kicker">Get in touch</Reveal>
        <Reveal as="h1" class="display" delay="d1" style="max-width:14ch">
          Let&apos;s build<br />
          visibility that <span class="em-green">moves business.</span>
        </Reveal>
        <Reveal as="p" class="lead" delay="d2" style="max-width:42ch">
          From streets to skylines, we help brands show up where attention matters most. Tell us about your campaign and we&apos;ll get back within one working day.
        </Reveal>

        <Reveal class="contact__cards" delay="d3">
          <a class="ccard" href={`mailto:${contact.email}`}>
            <span class="ccard__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path></svg></span>
            <span><span class="ccard__l">Email us</span><span class="ccard__v">{contact.email}</span></span>
          </a>
          <a class="ccard" href={contact.altPhoneHref}>
            <span class="ccard__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2Z"></path></svg></span>
            <span><span class="ccard__l">Call us</span><span class="ccard__v">{contact.altPhone}</span></span>
          </a>
          <a class="ccard" href={contact.phoneHref}>
            <span class="ccard__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2Z"></path></svg></span>
            <span><span class="ccard__l">Call us</span><span class="ccard__v">{contact.phone}</span></span>
          </a>
          <div class="ccard ccard--static">
            <span class="ccard__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11Z"></path><circle cx="12" cy="10" r="2.5"></circle></svg></span>
            <span><span class="ccard__l">Visit us</span><span class="ccard__v">{contact.address}</span></span>
          </div>
        </Reveal>
      </div>

      <Reveal class="contact__formwrap" delay="d2">
        <div data-contact-form-wrap>
          <form class="cform" data-contact-form data-endpoint={sheetsUrl} novalidate>
            <h2 class="h3" style="margin-bottom:6px">Start a campaign</h2>
            <p style="color:var(--muted);margin:0 0 22px">Fields marked * are required.</p>
            <div class="field">
              <label for="name">Full name *</label>
              <input id="name" name="name" type="text" placeholder="e.g. Aarav Sharma" required />
            </div>
            <div class="frow">
              <div class="field">
                <label for="email">Work email *</label>
                <input id="email" name="email" type="email" placeholder="you@company.com" required />
              </div>
              <div class="field">
                <label for="phone">Phone</label>
                <input id="phone" name="phone" type="tel" placeholder="+91" />
              </div>
            </div>
            <div class="frow">
              <div class="field">
                <label for="company">Company / brand</label>
                <input id="company" name="company" type="text" placeholder="Your brand" />
              </div>
              <div class="field">
                <label for="format">Format of interest</label>
                <select id="format" name="format">
                  <option value="">Select a format</option>
                  {formats.map((format) => <option value={format}>{format}</option>)}
                </select>
              </div>
            </div>
            <div class="field">
              <label for="message">Tell us about your campaign *</label>
              <textarea id="message" name="message" rows="4" placeholder="Goals, target cities, timeline and budget range…" required></textarea>
            </div>
            <p class="cform__error" role="alert" hidden data-contact-error></p>
            <button class="btn btn--primary btn--lg" type="submit" style="width:100%;justify-content:center">
              <span data-submit-text>Send enquiry</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
            </button>
            <p class="cform__note">By submitting you agree to be contacted by Conekt Ads about your enquiry.</p>
          </form>
        </div>

        <div class="cform__success" hidden data-contact-success>
          <div class="cform__check">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="m20 6-11 11-5-5"></path></svg>
          </div>
          <h2 class="h3">Thanks — we&apos;ve got it.</h2>
          <p style="color:var(--muted)">
            Our team will get back to you within one working day. For anything urgent, call
            <a href={contact.phoneHref} style="color:var(--accent);font-weight:700">{contact.phone}</a>.
          </p>
          <button class="btn btn--ghost" type="button" data-contact-reset>Send another enquiry</button>
        </div>
      </Reveal>
    </div>
  </section>
</BaseLayout>
